<file path="script.js">
class DatePlanner {

    constructor() {

        // ==========================
        // Datos de la cita
        // ==========================

        this.data = {

            accepted: false,

            plan: "",

            food: "",

            date: "",

            time: "",

            message: ""

        };

        // ==========================
        // Orden de las pantallas
        // ==========================

        this.pages = [

            "home",

            "question",

            "plan",

            "food",

            "date",

            "message",

            "finish"

        ];

        // ==========================
        // Página actual
        // ==========================

        this.currentPage = "home";

        // ==========================
        // Inicializar
        // ==========================

        this.init();

    }

    // ==================================
    // Inicio
    // ==================================

    init() {

        console.log("Date Planner iniciado.");

        this.setupCards();

        this.createToastContainer();

    }

    // ==================================
    // Cambiar pantalla
    // ==================================

    nextPage(pageId) {

        const current = document.querySelector(".page.active");

        if (current) {

            current.classList.remove("active");

        }

        document

            .getElementById(pageId)

            .classList

            .add("active");

        this.currentPage = pageId;

        this.updateProgress();

    }

    // ==================================
    // Barra de progreso
    // ==================================

    updateProgress() {

        const progress = document.getElementById("progress");

        if (!progress) return;

        const index = this.pages.indexOf(this.currentPage);

        const percent = ((index + 1) / this.pages.length) * 100;

        progress.style.width = percent + "%";

    }

    // ==================================
    // Toast
    // ==================================

    createToastContainer() {

        const div = document.createElement("div");

        div.id = "toast-container";

        document.body.appendChild(div);

    }

    showToast(message, type = "info") {

        const toast = document.createElement("div");

        toast.className = "toast " + type;

        toast.textContent = message;

        document

            .getElementById("toast-container")

            .appendChild(toast);

        setTimeout(() => {

            toast.classList.add("show");

        }, 50);

        setTimeout(() => {

            toast.classList.remove("show");

            setTimeout(() => {

                toast.remove();

            }, 300);

        }, 2500);

    }

    // ==================================
    // Botón "Sí"
    // ==================================

    accept() {

        this.data.accepted = true;

        this.showToast("Genial 😊");

        setTimeout(() => {

            this.nextPage("plan");

        }, 600);

    }

    // ==================================
    // Botón "Todavía no sé"
    // ==================================

    notSure() {

        this.showToast(

            "No pasa nada, puedes regresar cuando quieras 💚"

        );

    }

    // ==================================
    // Tarjetas
    // ==================================

    setupCards() {

        const cards = document.querySelectorAll(".card-option");

        cards.forEach(card => {

            card.addEventListener("click", () => {

                const group = card.parentElement;

                group

                    .querySelectorAll(".card-option")

                    .forEach(c => {

                        c.classList.remove("selected");

                    });

                card.classList.add("selected");

            });

        });

    }

}

const planner = new DatePlanner();

window.planner = planner;
