<file path="style.css">
/* ===========================
   VARIABLES
=========================== */

.progress-container{

    height:5px;

    background:#243146;

}

#progress{

    width:14%;

    height:100%;

    background:var(--primary);

    transition:.45s;

}

#toast-container{

    position:fixed;

    top:25px;

    right:25px;

    display:flex;

    flex-direction:column;

    gap:12px;

    z-index:999;

}

.toast{

    background:#172033;

    border:1px solid var(--border);

    color:white;

    padding:14px 18px;

    border-radius:12px;

    transform:translateX(350px);

    transition:.3s;

    box-shadow:0 10px 25px rgba(0,0,0,.25);

}

.toast.show{

    transform:translateX(0);

}

.toast.info{

    border-left:4px solid var(--primary);

}

:root{

    --bg:#0f172a;
    --card:#172033;
    --card-hover:#1f2d46;

    --primary:#4ade80;
    --primary-dark:#22c55e;

    --text:#f8fafc;
    --text2:#94a3b8;

    --border:#2b3648;

    --shadow:0 20px 50px rgba(0,0,0,.35);

}

/* ===========================
RESET
=========================== */

*{

    margin:0;
    padding:0;
    box-sizing:border-box;
    font-family:Inter,Segoe UI,sans-serif;

}

body{

    background:var(--bg);

    color:var(--text);

    min-height:100vh;

    display:flex;

    justify-content:center;

    align-items:center;

    overflow:hidden;

}

/* ===========================
BACKGROUND
=========================== */

.background{

    position:fixed;

    inset:0;

    background:

        radial-gradient(circle at top left,
        rgba(74,222,128,.18),
        transparent 30%),

        radial-gradient(circle at bottom right,
        rgba(34,197,94,.12),
        transparent 35%);

    z-index:-2;

}

/* pequeñas partículas */

.background::before{

    content:"";

    position:absolute;

    inset:0;

    background-image:

        radial-gradient(#4ade8030 1px,transparent 1px);

    background-size:40px 40px;

    animation:moveBackground 18s linear infinite;

    opacity:.35;

}

@keyframes moveBackground{

    from{

        transform:translateY(0);

    }

    to{

        transform:translateY(-40px);

    }

}

/* ===========================
APP
=========================== */

.container{

    width:min(92%,720px);

    background:rgba(23,32,51,.82);

    backdrop-filter:blur(18px);

    border:1px solid var(--border);

    border-radius:24px;

    box-shadow:var(--shadow);

    overflow:hidden;

}

/* ===========================
HEADER
=========================== */

header{

    display:flex;

    justify-content:space-between;

    align-items:center;

    padding:22px 28px;

    border-bottom:1px solid var(--border);

}

.logo{

    display:flex;

    align-items:center;

    gap:12px;

}

.dot{

    width:12px;

    height:12px;

    border-radius:50%;

    background:var(--primary);

    box-shadow:0 0 12px var(--primary);

}

.version{

    color:var(--text2);

    font-size:.9rem;

}

/* ===========================
PAGES
=========================== */

.page{

    display:none;

    padding:50px;

    animation:fade .45s ease;

}

.page.active{

    display:block;

}

@keyframes fade{

    from{

        opacity:0;

        transform:translateY(15px);

    }

    to{

        opacity:1;

        transform:translateY(0);

    }

}

h1{

    font-size:2.3rem;

    margin-bottom:18px;

}

p{

    color:var(--text2);

    line-height:1.7;

    margin-bottom:22px;

}

/* ===========================
BOTONES
=========================== */

button{

    cursor:pointer;

    border:none;

    border-radius:14px;

    padding:14px 22px;

    font-size:1rem;

    transition:.25s;

}

.primary{

    background:var(--primary);

    color:#052e16;

    font-weight:700;

}

.primary:hover{

    background:var(--primary-dark);

    transform:translateY(-2px);

}

.secondary{

    background:transparent;

    border:1px solid var(--border);

    color:var(--text);

}

.secondary:hover{

    background:var(--card-hover);

}

.actions{

    display:flex;

    gap:14px;

}

/* ===========================
CARDS
=========================== */

.cards{

    display:grid;

    grid-template-columns:repeat(auto-fit,minmax(140px,1fr));

    gap:18px;

    margin:35px 0;

}

.card-option{

    background:var(--card);

    border:1px solid var(--border);

    border-radius:18px;

    padding:28px;

    text-align:center;

    cursor:pointer;

    transition:.25s;

    user-select:none;

}

.card-option:hover{

    transform:translateY(-6px);

    border-color:var(--primary);

    box-shadow:0 10px 25px rgba(74,222,128,.18);

}

.card-option.selected{

    background:#163320;

    border-color:var(--primary);

}

.card-option{

    font-size:2rem;

}

.card-option span{

    display:block;

    margin-top:12px;

    font-size:1rem;

}

/* ===========================
INPUTS
=========================== */

input,
textarea{

    width:100%;

    background:var(--card);

    color:white;

    border:1px solid var(--border);

    border-radius:14px;

    padding:15px;

    outline:none;

}

textarea{

    resize:none;

    height:130px;

}

input:focus,
textarea:focus{

    border-color:var(--primary);

}

/* ===========================
SUMMARY
=========================== */

.summary{

    margin-top:30px;

    padding:20px;

    background:var(--card);

    border-radius:18px;

    border:1px solid var(--border);

}

/* ===========================
RESPONSIVE
=========================== */

@media(max-width:700px){

    .page{

        padding:28px;

    }

    .actions{

        flex-direction:column;

    }

}
